<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0D1117"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOTATO"
        android:textSize="32sp"
        android:textColor="#F0A500"
        android:textStyle="bold"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PrintBridge Server"
        android:textSize="16sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#161B22"
        android:padding="16dp"
        android:textColor="#C9D1D9"
        android:textSize="14sp"
        android:fontFamily="monospace"/>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="▶ DÉMARRER LE SERVEUR"
        android:backgroundTint="#238636"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="⏹ ARRÊTER"
        android:backgroundTint="#DA3633"
        android:textColor="#FFFFFF"/>

</LinearLayout>

